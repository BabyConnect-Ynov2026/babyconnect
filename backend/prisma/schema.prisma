// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Player {
  id        Int     @id @default(autoincrement())
  username  String  @unique
  email     String  @unique
  password  String
  fullName  String
  avatarUrl String?

  eloRating Int      @default(1000)
  wins      Int      @default(0) // to del
  losses    Int      @default(0) // to del
  draws     Int      @default(0) // to del
  goals     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reservations           Reservation[]
  tournamentParticipants TournamentParticipant[]
  wonTournaments         Tournament[]            @relation("TournamentWinner")

  redMatches1  Match[] @relation("RedPlayer1")
  redMatches2  Match[] @relation("RedPlayer2")
  blueMatches1 Match[] @relation("BluePlayer1")
  blueMatches2 Match[] @relation("BluePlayer2")
}

model Table {
  id        Int     @id @default(autoincrement())
  name      String  @unique
  location  String?
  available Boolean @default(true)

  matches      Match[]
  reservations Reservation[]
}

enum MatchStatus {
  pending
  ongoing
  completed
}

model Match {
  id      Int   @id @default(autoincrement())
  tableId Int
  table   Table @relation(fields: [tableId], references: [id])

  redTeamId1 Int
  redPlayer1 Player  @relation("RedPlayer1", fields: [redTeamId1], references: [id])
  redTeamId2 Int?
  redPlayer2 Player? @relation("RedPlayer2", fields: [redTeamId2], references: [id])
  redScore   Int     @default(0)

  blueTeamId1 Int
  bluePlayer1 Player  @relation("BluePlayer1", fields: [blueTeamId1], references: [id])
  blueTeamId2 Int?
  bluePlayer2 Player? @relation("BluePlayer2", fields: [blueTeamId2], references: [id])
  blueScore   Int     @default(0)

  tournamentId Int?
  tournament   Tournament? @relation(fields: [tournamentId], references: [id])

  status          MatchStatus @default(pending)
  durationSeconds Int         @default(0)
  startedAt       DateTime?
  finishedAt      DateTime?
  createdAt       DateTime    @default(now())
}

enum ReservationStatus {
  pending
  confirmed
  cancelled
  completed
}

model Reservation {
  id       Int    @id @default(autoincrement())
  playerId Int
  player   Player @relation(fields: [playerId], references: [id])
  tableId  Int
  table    Table  @relation(fields: [tableId], references: [id])

  startTime DateTime
  endTime   DateTime
  status    ReservationStatus @default(pending)
  notes     String            @default("")

  createdAt DateTime @default(now())
}

enum TournamentStatus {
  open
  in_progress
  finished
}

model Tournament {
  id          Int              @id @default(autoincrement())
  name        String
  description String           @default("")
  maxPlayers  Int              @default(16)
  status      TournamentStatus @default(open)
  startDate   DateTime?
  endDate     DateTime?

  winnerId Int?
  winner   Player? @relation("TournamentWinner", fields: [winnerId], references: [id])

  matches      Match[]
  participants TournamentParticipant[]
  createdAt    DateTime                @default(now())
}

model TournamentParticipant {
  tournamentId Int
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  playerId     Int
  player       Player     @relation(fields: [playerId], references: [id])

  joinedAt DateTime @default(now())

  @@id([tournamentId, playerId])
}
